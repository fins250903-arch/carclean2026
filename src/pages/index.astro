---
import MainLayout from '../layouts/MainLayout.astro';
import { generateRegionMetadata, generateJsonLd } from '../lib/seo';
import { regionalPosts } from '../data/regionalPosts';
import { generateQuestionnaireJsonLd } from '../data/questionnaireTestimonials';
import JsonLd from '../components/seo/JsonLd.astro';

// Astro Components
import Hero from '../components/sections/Hero.astro';
import RegionAIContent from '../components/sections/RegionAIContent.astro';
import Problem from '../components/sections/Problem.astro';
import Solution from '../components/sections/Solution.astro';
import Comparison from '../components/sections/Comparison.astro';
import Campaign from '../components/sections/Campaign.astro';
import CTA from '../components/sections/CTA.astro';
import FAQ from '../components/sections/FAQ.astro';
import Reasons from '../components/sections/Reasons.astro';
import Benefits from '../components/sections/Benefits.astro';
import Roadmap from '../components/sections/Roadmap.astro';
import RegionalAchievements from '../components/sections/RegionalAchievements.astro';
import Targets from '../components/sections/Targets.astro';
import AreaCoverage from '../components/sections/AreaCoverage.astro';
import Flow from '../components/sections/Flow.astro';
import Profile from '../components/sections/Profile.astro';
import Expertise from '../components/sections/Expertise.astro';
import Pricing from '../components/sections/Pricing.astro';
import Closing from '../components/sections/Closing.astro';
import ServiceMutualLink from '../components/sections/ServiceMutualLink.astro';

// React Components
import { RegionProvider } from '../lib/RegionContext';
import QuestionnaireTestimonials from '../components/sections/QuestionnaireTestimonials';
import Testimonials from '../components/sections/Testimonials';
import Blog from '../components/sections/Blog';
import ContactForm from '../components/sections/ContactForm';
import FloatingCTA from '../components/sections/FloatingCTA';

const regionName = '大阪府';
const niche = 'car';
const path = '/';

const post = regionalPosts[regionName] || regionalPosts[regionName.replace('府', '').replace('県', '')];
const displayName = post?.displayName || regionName;
const questionnaireStructuredData = generateQuestionnaireJsonLd(regionName, displayName, path);
const regionOverrides = {
    displayName,
    aiSummary: post?.aiSummary,
    article: post?.title && post?.excerpt && post?.image ? {
        headline: post.title,
        description: post.excerpt,
        image: post.image,
    } : undefined,
    localBusiness: post?.structuredData ? {
        areaServed: post.structuredData.areaServed,
        description: post.structuredData.description,
        geo: post.structuredData.geo
            ? {
                ...post.structuredData.geo,
                addressRegion: regionName,
            }
            : undefined,
    } : undefined,
};

const metadata = generateRegionMetadata(regionName, path, niche);
const jsonLdData = generateJsonLd(regionName, path, regionOverrides, niche);
const combinedJsonLd = [...jsonLdData, ...questionnaireStructuredData];
---

<MainLayout 
  title={metadata.title}
  description={metadata.description}
  keywords={metadata.keywords}
  canonical={metadata.alternates.canonical}
  ogImage={'/images/fv.png'}
>
  <JsonLd slot="head" data={combinedJsonLd} />

  <RegionProvider client:load regionName={regionName} displayName={displayName} niche={niche} path={path}>
    <main class="min-h-screen bg-white pb-20 md:pb-0">
      <Hero regionName={regionName} displayName={displayName} niche={niche} />
      <Campaign displayName={displayName} />
      <RegionAIContent regionName={regionName} displayName={displayName} />
      <Comparison displayName={displayName} />
      <Problem regionName={regionName} displayName={displayName} niche={niche} />
      <Solution regionName={regionName} displayName={displayName} niche={niche} />
      <CTA />
      <Reasons displayName={displayName} regionName={regionName} />
      <Benefits />
      <Roadmap displayName={displayName} />
      
      <QuestionnaireTestimonials client:visible displayName={displayName} />
      <RegionalAchievements regionName={regionName} displayName={displayName} niche={niche} />
      <Targets />
      <Campaign displayName={displayName} />
      <AreaCoverage regionName={regionName} />
      <CTA />
      <Flow niche={niche} />
      <Profile displayName={displayName} />
      <Expertise />
      <Pricing regionName={regionName} niche={niche} />
      <Campaign displayName={displayName} />
      <AreaCoverage regionName={regionName} />
      <CTA />
      <FAQ niche={niche} />
      <Blog client:visible regionName={regionName} displayName={displayName} />
      <ServiceMutualLink regionName={regionName} displayName={displayName} niche={niche} path={path} />
      <ContactForm client:visible regionName={regionName} />
      <Closing regionName={regionName} displayName={displayName} niche={niche} path={path} />
      <FloatingCTA client:visible />
    </main>
  </RegionProvider>
</MainLayout>

