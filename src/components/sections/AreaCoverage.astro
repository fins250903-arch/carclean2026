---
import { regionAreaData } from '../../data/regionAreaData';

interface Props {
  regionName: string;
}

const { regionName } = Astro.props;
const areaConfig = regionAreaData[regionName];

if (!areaConfig) return null;
---

<section class="py-16 bg-gradient-to-b from-gray-50 to-white" id="area-coverage">
    <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-800 px-4 py-2 rounded-full text-sm font-bold mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                出張対応エリア
            </div>
            <h2 class="text-2xl md:text-3xl font-black text-gray-900 mb-4 leading-tight">
                {areaConfig.headline}
            </h2>
            <p class="text-gray-600 text-base md:text-lg leading-relaxed max-w-3xl mx-auto">
                {areaConfig.reassurance}
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-4 mb-10">
            {areaConfig.areas.map((group) => (
                <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:shadow-md transition-shadow">
                    <h3 class="font-bold text-blue-900 text-base mb-2 flex items-center gap-1.5">
                        <span class="w-2 h-2 bg-blue-500 rounded-full inline-block flex-shrink-0"></span>
                        {group.label}
                    </h3>
                    <p class="text-gray-700 text-sm leading-relaxed">
                        {group.cities.join('、')}
                    </p>
                </div>
            ))}
        </div>

        <div class="text-center">
            <a
                href="https://lin.ee/Xs8Orp2"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white text-lg md:text-xl font-bold px-8 py-5 rounded-2xl shadow-lg transition-all hover:scale-105 hover:shadow-xl"
            >
                <span>{areaConfig.ctaText}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
            </a>
        </div>
    </div>
</section>
