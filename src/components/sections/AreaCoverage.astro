---
import { regionAreaData } from '../../data/regionAreaData';

interface Props {
  regionName: string;
}

const { regionName } = Astro.props;

// Get region-specific data
const regionData = regionAreaData[regionName];

if (!regionData) {
  console.warn(`No area data found for region: ${regionName}`);
}

// Flatten all cities from all area groups
const allCities: string[] = [];
if (regionData) {
  regionData.areas.forEach(areaGroup => {
    allCities.push(...areaGroup.cities);
  });
}
---

<section class="py-10 bg-gray-50 border-y border-gray-100">
    <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-8">
                {regionData?.headline || `${regionName}の出張対応エリア`}
            </h2>
            <p class="text-gray-600 text-center mb-8">
                {regionData?.reassurance || 'お電話一本で、ご自宅やご指定の場所までプロの機材を積んで伺います。電源不要、水道不要（タンク持参）ですので、駐車場があればどこでも作業可能です。'}
            </p>
            
            <div class="bg-white p-6 md:p-10 rounded-3xl shadow-sm border border-gray-100">
                <div class="space-y-6">
                    {regionData && regionData.areas.map((areaGroup) => (
                        <div>
                            <h3 class="text-lg font-bold text-gray-800 mb-3 pb-2 border-b border-gray-200">
                                {areaGroup.label}
                            </h3>
                            <div class="flex flex-wrap gap-2">
                                {areaGroup.cities.map((city) => (
                                    <span class="bg-gray-50 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium border border-gray-100">
                                        {city}
                                    </span>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
                <div class="mt-8 pt-8 border-t border-gray-100 text-center">
                    <p class="text-sm text-gray-500 italic">
                        ※地域により出張費が発生する場合がございます。詳しくはお見積もり時にご案内いたします。
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
