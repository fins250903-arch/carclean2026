---
interface Props {
  displayName: string;
}

const { displayName } = Astro.props;
---

<section class="py-8 bg-accent/10 border-y-4 border-accent">
    <div class="container mx-auto px-8 text-center">
        <h2 class="text-3xl md:text-5xl font-black text-red-600 mb-4 drop-shadow-sm bg-white/80 inline-block px-4 py-2 rounded-lg">
            {displayName}WEBキャンペーン
        </h2>
        <div class="bg-white px-12 py-10 rounded-xl shadow-xl max-w-3xl mx-auto transform rotate-1 hover:rotate-0 transition-transform duration-300">
            <p class="text-2xl font-bold text-gray-800 mb-2">
                今なら、通常2,000円の
            </p>
            <p class="text-4xl md:text-6xl font-black text-accent mb-4">
                抗菌コート 無料！
            </p>
            <p class="text-gray-600">
                クリーニング後のきれいな状態を長持ちさせ、菌の繁殖を抑えます。
            </p>
        </div>
    </div>
</section>
