---
import { STORE_NAME } from '../../lib/site';

interface Props {
  displayName: string;
}

const { displayName } = Astro.props;
---

<section class="py-10 bg-white">
    <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto bg-gray-50 rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm flex flex-col md:flex-row items-center gap-10">
            <div class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden shadow-xl border-4 border-white flex-shrink-0">
                <img 
                    src="/images/representative_new.webp" 
                    alt="代表 今村 優作" 
                    class="w-full h-full object-cover"
                />
            </div>
            <div class="flex-1 text-center md:text-left">
                <div class="inline-block bg-primary/10 text-primary text-xs font-bold px-3 py-1 rounded-full mb-4">
                    代表あいさつ
                </div>
                <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-6">
                    「その場の困った！」に、<br class="md:hidden" />
                    プロの技術で応えたい。
                </h2>
                <p class="text-gray-600 leading-relaxed mb-6">
                    はじめまして。{STORE_NAME} 代表の今村です。<br />
                    私たちはこれまで、{displayName}の地で数多くの「車内トラブル」を解決してきました。<br />
                    車はただの移動手段ではなく、家族の思い出が詰まった場所、あるいは仕事の大切なパートナーです。<br />
                    だからこそ、私たちは単に洗うだけでなく「心から安心できる空間」を取り戻すことを使命としています。
                </p>
                <div class="font-bold text-gray-800">
                    {STORE_NAME} 代表 今村 優作
                </div>
            </div>
        </div>
    </div>
</section>
