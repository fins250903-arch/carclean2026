---
import { STORE_NAME } from '../../lib/site';

interface Props {
  regionName: string;
  displayName: string;
  niche?: 'car' | 'truck';
}

const { regionName, displayName, niche = 'car' } = Astro.props;
const isTruck = niche === 'truck';

const subtitle = isTruck 
    ? `${displayName}トラックキャビン清掃専門店/キャビン洗浄`
    : `${displayName}車内クリーニング専門店/シート洗浄`;

const fvImage = isTruck ? "/images/truck-fv.png" : "/images/fv_change_v2.png";
---

<section class="relative w-full min-h-screen md:h-[95vh] flex items-center bg-white overflow-hidden">
    <div class="absolute inset-0 w-full h-full z-0">
        <img
            src={fvImage}
            alt={`${displayName}対応 ${STORE_NAME}`}
            class="w-full h-full object-cover object-[center_bottom] md:object-right opacity-90"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-white via-white/80 to-transparent z-10"></div>
    </div>

    <div class="container mx-auto px-8 md:px-16 z-20 relative">
        <div class="max-w-3xl">
            {/* 1. 小見出し */}
            <p class="text-lg md:text-2xl font-bold text-gray-800 mb-2">
                {subtitle}
            </p>

            {/* 2. メインキャッチコピー */}
            <h1 class="text-6xl md:text-8xl lg:text-9xl font-black text-blue-900 leading-tight mb-4 tracking-tighter">
                早急に解決！
            </h1>

            {/* 3. サブキャッチ */}
            <p class="text-2xl md:text-4xl font-bold text-gray-700 mb-8">
                {displayName}の車内クリーニング・消臭洗浄
            </p>
            
            {/* 4. キャンペーンボックス（黄色） */}
            <div class="bg-yellow-100 border-4 border-yellow-400 p-6 md:p-8 rounded-3xl shadow-xl mb-6 inline-block w-full max-w-xl">
                <p class="text-xl md:text-2xl font-bold text-gray-800 mb-2">
                    今なら、通常2,000円の
                </p>
                <p class="text-4xl md:text-6xl font-black text-red-600 animate-pulse">
                    抗菌コート 無料！
                </p>
            </div>

            {/* 5. 緊急トラブルボックス（白背景・赤枠） */}
            <div class="bg-white border-4 border-red-500 p-6 md:p-8 rounded-3xl shadow-2xl mb-10 w-full max-w-xl">
                <p class="text-xl md:text-2xl font-bold text-gray-800 mb-2">
                    ディーラーで5日待てますか？
                </p>
                <p class="text-5xl md:text-7xl font-black text-red-600">
                    絶対ムリ！
                </p>
            </div>

            {/* 6. CTAボタン */}
            <div class="flex flex-col sm:flex-row gap-4 mb-8">
                <a
                    href="https://lin.ee/Xs8Orp2"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bg-[#06C755] hover:bg-[#05a346] text-white font-black py-5 px-10 rounded-full shadow-2xl text-2xl md:text-3xl transition-transform hover:scale-105 text-center flex items-center justify-center gap-3"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="lucide lucide-message-circle"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                    LINEで見積もり
                </a>
                <a
                    href="https://www.instagram.com/carinterierclean/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bg-gradient-to-tr from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] hover:opacity-90 text-white font-black py-5 px-10 rounded-full shadow-2xl text-2xl md:text-3xl transition-transform hover:scale-105 text-center flex items-center justify-center gap-3"
                >
                    📸 インスタDM相談
                </a>
            </div>

            {/* 7. 補足テキスト */}
            <p class="text-xl md:text-2xl font-black text-gray-800 leading-relaxed bg-white/60 inline-block px-4 py-2 rounded-lg">
                嘔吐・灯油こぼしの緊急トラブル <span class="text-red-600 underline decoration-4">すぐ対応</span> 駆けつけます
            </p>
        </div>
    </div>
</section>

<style>
    h1 {
        text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
    }
</style>
