---
interface Props {
  regionName: string;
  displayName: string;
  niche?: 'car' | 'truck' | 'coating';
  path: string;
}

const { regionName, displayName, niche = 'car', path } = Astro.props;

if (niche === 'coating') return null;

const isTruck = niche === 'truck';
const targetNiche = isTruck ? 'car' : 'truck';
const targetDisplayName = isTruck ? '乗用軁E : '大型トラチE・バス';

// Construct the target path
let targetLink = '';
if (path === '/' || path === '') {
    targetLink = isTruck ? '/' : '/regions/osaka-truck';
} else {
    targetLink = isTruck 
        ? path.replace(/-truck$/, '') 
        : `${path}-truck`;
}

const targetImage = isTruck ? '/images/fv_change_v2.png' : '/images/truck-fv.png';
---

<section class="py-12 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-2xl md:text-3xl font-bold text-center mb-8 text-gray-900">
                {isTruck ? '乗用軁E : 'トラチE・法人軁E}の渁Eもお任せください
            </h2>
            
            <a 
                href={targetLink}
                class="group relative flex flex-col md:flex-row items-center bg-white rounded-2xl shadow-xl overflow-hidden border-2 border-primary/20 hover:border-primary transition-all duration-300"
            >
                <div class="w-full md:w-1/3 h-48 relative overflow-hidden">
                    <img 
                        src={targetImage} 
                        alt={targetDisplayName}
                        class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-500"
                    />
                    <div class="absolute inset-0 bg-primary/10 group-hover:bg-transparent transition-colors"></div>
                </div>
                
                <div class="flex-1 p-6 md:p-8">
                    <div class="inline-block bg-primary text-white text-xs font-bold px-3 py-1 rounded-full mb-3">
                        {isTruck ? 'FOR PASSENGER CAR' : 'FOR BUSINESS USE'}
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-2">
                        {displayName}の{targetDisplayName}渁E・消E専門ペEジへ
                    </h3>
                    <p class="text-gray-600 mb-4 text-sm md:text-base">
                        {isTruck 
                            ? '嘔吐、EチE臭、中古車E生活臭など、乗用車EあらめEお悩みをスピEド解決ぁEします、E
                            : '長距離ドライバEの快適な空間を。タバコ臭めE脂汚れを徹底洗流E、渁Eなキャビンを取り戻します、E
                        }
                    </p>
                    <span class="text-primary font-bold flex items-center gap-2">
                        詳細を見る
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                        </svg>
                    </span>
                </div>
            </a>
        </div>
    </div>
</section>
