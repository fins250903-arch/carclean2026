---
import { faqData, truckFaqData } from '../../data/seoData';

interface Props {
  niche?: 'car' | 'truck';
}

const { niche = 'car' } = Astro.props;
const isTruck = niche === 'truck';
const faqs = isTruck ? truckFaqData : faqData;
---

<section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">
            よくあるご質問
        </h2>

        <div class="max-w-3xl mx-auto space-y-6">
            {faqs.map((item) => (
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h3 class="flex items-start gap-3 font-bold text-lg text-gray-900 mb-3">
                        <span class="bg-primary text-white w-8 h-8 rounded-full flex-shrink-0 flex items-center justify-center text-sm">Q</span>
                        {item.q}
                    </h3>
                    <div class="flex items-start gap-3 text-gray-700 ml-2">
                        <span class="text-red-500 font-bold text-lg w-6 text-center">A.</span>
                        <p>{item.a}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
