---
interface Props {
  regionName: string;
  niche?: 'car' | 'truck';
}

const { regionName, niche = 'car' } = Astro.props;
const isTruck = niche === 'truck';

const carPricing = [
    { name: "軽自動車・軽SUV", price: "22,000", detail: "4人乗り以下。シート洗浄・床面洗浄セット。消臭追加：+3,000円" },
    { name: "普通車(3/5ナンバー)", price: "28,000", detail: "5人乗り以下。シート洗浄・床面洗浄セット。消臭追加：+4,000円" },
    { name: "大型車・ミニバン", price: "36,000", detail: "6人乗り以上。シート洗浄・床面洗浄セット。消臭追加：+5,000円" },
    { name: "座席シート単体", price: "18,000", detail: "1脚徹底洗浄。消臭追加：+7,000円" }
];

const truckPricing = [
    { name: "トラックキャビン", price: "35,000", detail: "キャビン全体・除菌。10t車目安。ベッド部は別途。" },
    { name: "後部座席のみ", price: "22,000", detail: "徹底洗浄。消臭追加：+7,000円" },
    { name: "フロア床(前席のみ)", price: "9,000", detail: "徹底洗浄。消臭追加：+7,000円" },
    { name: "エアコン内部(簡易)", price: "10,000", detail: "臭いの元をリフレッシュ" }
];

const pricing = isTruck ? truckPricing : carPricing;
---

<section class="py-10 bg-white" id="pricing">
    <div class="container mx-auto px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-800 mb-4">料金プラン</h2>
            <p class="text-gray-600">出張費込みの明快な料金体系です。</p>
        </div>

        <div class="max-w-4xl mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            {pricing.map((plan) => (
                <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100 flex flex-col text-center">
                    <h3 class="font-bold text-gray-800 mb-2">{plan.name}</h3>
                    <div class="mb-4">
                        <span class="text-sm text-gray-500">税込</span>
                        <span class="text-2xl font-black text-primary ml-1">{plan.price}</span>
                        {plan.price !== "別途お見積り" && <span class="text-sm text-primary">円〜</span>}
                    </div>
                    <p class="text-xs text-gray-500 leading-relaxed mb-6 flex-1">
                        {plan.detail}
                    </p>
                    <a href="#contact" class="bg-white border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold py-2 px-4 rounded-full text-sm transition-all shadow-sm">
                        詳しく相談する
                    </a>
                </div>
            ))}
        </div>
        
        <div class="mt-12 bg-blue-50 border border-blue-100 rounded-2xl p-6 max-w-2xl mx-auto text-center">
            <p class="text-sm text-gray-700 font-bold mb-2">
                【{regionName}エリア限定】
            </p>
            <p class="text-gray-600 text-sm">
                現在、キャンペーンにつき出張料無料にて承っております。<br />
                （※一部遠方地域を除く。詳細はお問い合わせください）
            </p>
        </div>
    </div>
</section>
