---
interface Props {
  regionName: string;
  niche?: 'car' | 'truck';
}

const { regionName, niche = 'car' } = Astro.props;
const isTruck = niche === 'truck';
---

<section class="py-20 bg-white" id="pricing">
    <div class="container mx-auto px-4 md:px-8 max-w-5xl">
        <div class="text-center mb-14">
            <h2 class="text-4xl md:text-6xl font-black text-gray-900 mb-4">料金プラン</h2>
            <p class="text-lg md:text-xl text-gray-600">
                {regionName}エリアは出張費無料！プロの機材と技術で、車内の悩みを根本解決します。
            </p>
        </div>

        {/* ===== 車種別 基本料金テーブル ===== */}
        <div class="mb-10 bg-gray-50 rounded-3xl p-6 md:p-10 border border-gray-200 shadow-sm">
            <h3 class="text-2xl md:text-3xl font-black text-blue-900 mb-6 flex items-center gap-3">
                <span class="w-1.5 h-10 bg-primary rounded-full inline-block"></span>
                {isTruck ? 'トラックキャビン' : '車種別料金表'}
            </h3>

            {/* PC: テーブル / SP: カード */}
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-blue-900 text-white">
                            <th class="px-4 py-3 text-sm md:text-base font-bold rounded-tl-xl">車種・区分</th>
                            <th class="px-4 py-3 text-sm md:text-base font-bold text-center">基本料金<br /><span class="text-xs font-normal">(税込)</span></th>
                            <th class="px-4 py-3 text-sm md:text-base font-bold text-center rounded-tr-xl">消臭・脱臭<br /><span class="text-xs font-normal">セット料金(税込)</span></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        {!isTruck && (
                            <>
                            <tr class="hover:bg-blue-50 transition-colors">
                                <td class="px-4 py-4">
                                    <p class="font-bold text-gray-900 text-base md:text-lg">軽自動車・軽SUV</p>
                                    <p class="text-gray-500 text-xs md:text-sm mt-0.5">（4人乗り以下）</p>
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="text-2xl md:text-3xl font-black text-primary">22,000</span>
                                    <span class="text-sm text-primary font-bold">円</span>
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="text-2xl md:text-3xl font-black text-orange-500">25,000</span>
                                    <span class="text-sm text-orange-500 font-bold">円</span>
                                    <p class="text-xs text-gray-400 mt-0.5">(+3,000円)</p>
                                </td>
                            </tr>
                            <tr class="hover:bg-blue-50 transition-colors bg-blue-50/50">
                                <td class="px-4 py-4">
                                    <p class="font-bold text-gray-900 text-base md:text-lg">普通車</p>
                                    <p class="text-gray-500 text-xs md:text-sm mt-0.5">（3・5ナンバー / 5人乗り以下）</p>
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="text-2xl md:text-3xl font-black text-primary">28,000</span>
                                    <span class="text-sm text-primary font-bold">円</span>
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="text-2xl md:text-3xl font-black text-orange-500">32,000</span>
                                    <span class="text-sm text-orange-500 font-bold">円</span>
                                    <p class="text-xs text-gray-400 mt-0.5">(+4,000円)</p>
                                </td>
                            </tr>
                            <tr class="hover:bg-blue-50 transition-colors">
                                <td class="px-4 py-4">
                                    <p class="font-bold text-gray-900 text-base md:text-lg">大型車・SUV・ミニバン</p>
                                    <p class="text-gray-500 text-xs md:text-sm mt-0.5">（6人乗り以上）</p>
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="text-2xl md:text-3xl font-black text-primary">36,000</span>
                                    <span class="text-sm text-primary font-bold">円</span>
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="text-2xl md:text-3xl font-black text-orange-500">41,000</span>
                                    <span class="text-sm text-orange-500 font-bold">円</span>
                                    <p class="text-xs text-gray-400 mt-0.5">(+5,000円)</p>
                                </td>
                            </tr>
                            </>
                        )}
                        {/* トラック行（常時表示 / トラックLPでは強調） */}
                        <tr class={isTruck ? "bg-orange-50 border-2 border-orange-300" : "hover:bg-blue-50 transition-colors bg-gray-50"}>
                            <td class="px-4 py-4">
                                <p class="font-bold text-gray-900 text-base md:text-lg">トラックキャビン 10t</p>
                                {isTruck && <p class="text-gray-500 text-xs md:text-sm mt-0.5">ベッド部等は別途お見積もり</p>}
                            </td>
                            <td class="px-4 py-4 text-center">
                                <span class={`text-2xl md:text-3xl font-black ${isTruck ? 'text-orange-500' : 'text-primary'}`}>35,000</span>
                                <span class={`text-sm font-bold ${isTruck ? 'text-orange-500' : 'text-primary'}`}>円〜</span>
                            </td>
                            <td class="px-4 py-4 text-center text-gray-400 text-sm">
                                別途お見積もり
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-gray-400 mt-4 text-right">※ 料金はすべて税込表示です。出張費は{regionName}エリア無料。</p>
        </div>

        {/* ===== 【個別】部分クリーニング ===== */}
        <div class="mb-10 bg-gray-50 rounded-3xl p-6 md:p-10 border border-gray-200 shadow-sm">
            <h3 class="text-2xl md:text-3xl font-black text-blue-900 mb-2 flex items-center gap-3">
                <span class="w-1.5 h-10 bg-primary rounded-full inline-block"></span>
                【個別】部分クリーニング
            </h3>
            <p class="text-gray-500 text-sm mb-6">消臭・脱臭を追加する場合は一律 <strong class="text-orange-500">+7,000円</strong></p>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-blue-800 text-white">
                            <th class="px-4 py-3 text-sm md:text-base font-bold rounded-tl-xl">清掃箇所</th>
                            <th class="px-4 py-3 text-sm md:text-base font-bold text-center">基本料金<br /><span class="text-xs font-normal">(税込)</span></th>
                            <th class="px-4 py-3 text-sm md:text-base font-bold text-center rounded-tr-xl">消臭・脱臭<br /><span class="text-xs font-normal">セット(税込)</span></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        <tr class="hover:bg-blue-50 transition-colors">
                            <td class="px-4 py-3 font-bold text-gray-900 text-sm md:text-base">座席シート単体（1脚）</td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xl md:text-2xl font-black text-primary">18,000</span>
                                <span class="text-xs text-primary font-bold">円</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xl md:text-2xl font-black text-orange-500">25,000</span>
                                <span class="text-xs text-orange-500 font-bold">円</span>
                            </td>
                        </tr>
                        <tr class="hover:bg-blue-50 transition-colors bg-blue-50/30">
                            <td class="px-4 py-3 font-bold text-gray-900 text-sm md:text-base">後部座席シートのみ</td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xl md:text-2xl font-black text-primary">22,000</span>
                                <span class="text-xs text-primary font-bold">円</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xl md:text-2xl font-black text-orange-500">29,000</span>
                                <span class="text-xs text-orange-500 font-bold">円</span>
                            </td>
                        </tr>
                        <tr class="hover:bg-blue-50 transition-colors">
                            <td class="px-4 py-3 font-bold text-gray-900 text-sm md:text-base">フロア床のみ（前席）</td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xl md:text-2xl font-black text-primary">9,000</span>
                                <span class="text-xs text-primary font-bold">円</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xl md:text-2xl font-black text-orange-500">16,000</span>
                                <span class="text-xs text-orange-500 font-bold">円</span>
                            </td>
                        </tr>
                        <tr class="hover:bg-blue-50 transition-colors bg-blue-50/30">
                            <td class="px-4 py-3 font-bold text-gray-900 text-sm md:text-base">フロア床のみ（後部席）</td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xl md:text-2xl font-black text-primary">8,000</span>
                                <span class="text-xs text-primary font-bold">円</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="text-xl md:text-2xl font-black text-orange-500">15,000</span>
                                <span class="text-xs text-orange-500 font-bold">円</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        {/* ===== 追加オプション費用 ===== */}
        <div class="mb-14 bg-gray-50 rounded-3xl p-6 md:p-10 border border-gray-200 shadow-sm">
            <h3 class="text-2xl md:text-3xl font-black text-blue-900 mb-6 flex items-center gap-3">
                <span class="w-1.5 h-10 bg-primary rounded-full inline-block"></span>
                追加オプション費用
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                {[
                    { name: '消臭・脱臭（嘔吐・糞尿・激臭）', price: '3,000円〜7,000円' },
                    { name: '抗菌コート', price: '2,000円' },
                    { name: '防臭＋抗菌コート', price: '5,000円' },
                    { name: 'オゾン装置使用', price: '5,000円' },
                    { name: '発電機等 電源持込', price: '5,000円' },
                    { name: '天井部洗浄（タバコ ヤニ除去）', price: '12,000円' },
                    { name: '車灯油こぼし専用洗浄（1席あたり）', price: '30,000円' },
                    { name: 'ペット毛追加', price: '5,000円' },
                    { name: '革張りシート（洗剤保湿剤変更）', price: '5,000円' },
                    { name: 'エアコン内部洗浄（簡易洗浄）', price: '10,000円' },
                ].map((opt) => (
                    <div class="flex justify-between items-center bg-white border border-gray-200 rounded-xl px-4 py-3 gap-4">
                        <span class="text-gray-700 text-sm md:text-base font-medium">{opt.name}</span>
                        <span class="text-primary font-black text-base md:text-lg whitespace-nowrap">{opt.price}</span>
                    </div>
                ))}
            </div>
            <p class="text-xs text-gray-400 mt-4">※ 料金はすべて税込表示です。車両の状態により変動する場合があります。</p>
        </div>

        {/* ===== CTA バナー ===== */}
        <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-3xl p-8 md:p-16 text-white shadow-2xl relative overflow-hidden">
            <div class="relative z-10 text-center">
                <h3 class="text-2xl md:text-4xl font-black mb-4">【{regionName}のお客様へ】</h3>
                <p class="text-lg md:text-2xl font-bold leading-relaxed mb-8">
                    現在、キャンペーンにつき<span class="text-yellow-400 underline decoration-4">出張料無料</span>にて承っております。<br />
                    「今すぐどうにかしたい」トラブル、プロの特急便にお任せください！
                </p>
                <a
                    href="https://lin.ee/Xs8Orp2"
                    class="inline-flex items-center justify-center gap-3 bg-[#06C755] text-white font-black py-5 px-10 rounded-full text-xl shadow-xl hover:scale-105 transition-transform"
                >
                    LINEで無料見積もり
                </a>
            </div>
            <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-96 h-96 bg-blue-400/20 rounded-full blur-3xl pointer-events-none"></div>
        </div>
    </div>
</section>
