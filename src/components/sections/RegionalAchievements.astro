---
import { localCaseStudies } from '../../data/localCaseStudies';

interface Props {
  regionName: string;
  displayName: string;
  niche?: 'car' | 'truck';
}

const { regionName, displayName, niche = 'car' } = Astro.props;
const isTruck = niche === 'truck';

// Filter cases by niche and region
const nicheCases = localCaseStudies.filter(c => c.niche === niche);

// Standardize names for filtering
const regionCases = nicheCases.filter(c => 
    c.region === regionName || 
    c.region === displayName || 
    c.region === regionName.replace('府', '').replace('県', '')
);

// Get up to 3 cases
const displayCases = regionCases.length > 0 ? regionCases.slice(0, 3) : nicheCases.slice(0, 3);
---

<section class="py-20 bg-white border-t border-gray-100">
    <div class="container mx-auto px-8 max-w-6xl">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-black text-gray-900 mb-4">
                {displayName}周辺の施工事例
            </h2>
            <p class="text-xl text-gray-600 font-bold">
                実際に当店をご利用いただいたお客様の施工実績です。
            </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10 mb-16">
            {displayCases.map((item) => (
                <div class="bg-white rounded-[32px] shadow-2xl border border-gray-100 overflow-hidden flex flex-col group hover:scale-[1.02] transition-transform">
                    <div class="relative h-64 overflow-hidden">
                        <img
                            src={item.image}
                            alt={item.title}
                            class="w-full h-full object-cover transition-transform group-hover:scale-110"
                        />
                        <div class="absolute top-4 left-4 bg-primary text-white text-xs font-black px-4 py-2 rounded-full shadow-lg">
                            {item.city}
                        </div>
                    </div>
                    <div class="p-8 flex-1 flex flex-col">
                        <h3 class="text-xl font-black text-gray-900 mb-6 leading-tight group-hover:text-primary transition-colors">
                            {item.title}
                        </h3>
                        
                        <div class="space-y-4 mb-6 flex-1">
                            <div>
                                <h4 class="font-black text-blue-900 text-sm flex items-center gap-2 mb-1">
                                    <span class="w-1.5 h-4 bg-primary rounded-full"></span> お悩み
                                </h4>
                                <p class="text-gray-600 text-sm leading-relaxed line-clamp-3">
                                    {item.problem}
                                </p>
                            </div>
                            
                            <div class="bg-blue-50 p-4 rounded-2xl border border-blue-100">
                                <h4 class="font-black text-primary text-sm mb-1">プロの解決法</h4>
                                <p class="text-gray-700 text-xs leading-relaxed line-clamp-3">
                                    {item.professionalInsight}
                                </p>
                            </div>
                        </div>
                        
                        <div class="pt-4 border-t border-gray-100 mt-auto">
                            <p class="font-black text-gray-900 text-sm italic">
                                <span class="text-amber-500 mr-1">Result:</span>
                                {item.result}
                            </p>
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <div class="text-center">
            <div class="inline-block bg-gray-50 p-10 rounded-[40px] border-4 border-dashed border-gray-200 w-full max-w-3xl">
                <h3 class="text-2xl md:text-3xl font-black text-gray-900 mb-4 flex items-center justify-center gap-3">
                    📸 エリアごとの最新実績を公開中！
                </h3>
                <p class="text-gray-600 text-lg mb-8">
                    各地域での様々なトラブル解決事例や、実際のビフォーアフターを公式ブログで詳しくご紹介しています。
                </p>
                <a 
                    href="https://carinteriorcleaning.jp/blog/jisseki/" 
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block bg-primary hover:bg-primary/90 text-white font-black py-5 px-12 rounded-full shadow-2xl transition-transform hover:scale-105 text-xl"
                >
                    作業実績一覧を見る（公式ブログ）
                </a>
            </div>
        </div>
    </div>
</section>
