---
interface Props {
  regionName: string;
  displayName: string;
  niche?: 'car' | 'truck';
}

const { displayName } = Astro.props;
---

<section class="py-10 bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-8 max-w-5xl">
        <h2 class="text-3xl font-bold text-center text-gray-800 mb-8">
            {displayName}周辺の施工実績
        </h2>
        
        <div class="text-center">
            <div class="inline-block bg-white p-6 md:p-8 rounded-2xl shadow-sm border-2 border-primary/20 w-full max-w-2xl">
                <h3 class="text-xl font-bold text-gray-800 mb-3 flex items-center justify-center gap-2">
                    <span>📸</span> エリアごとの最新作業実績を公開中！
                </h3>
                <p class="text-gray-600 text-sm mb-6">
                    各地域での様々なトラブル解決事例や、実際のビフォーアフターをブログで詳しくご紹介しています。
                </p>
                <a 
                    href="https://carinteriorcleaning.jp/blog/jisseki/" 
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block bg-primary hover:bg-primary/90 text-white font-bold py-4 px-10 rounded-full shadow-lg transition-transform hover:scale-105"
                >
                    作業実績一覧を見る（公式ブログ）
                </a>
            </div>
        </div>
    </div>
</section>
