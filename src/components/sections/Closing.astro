---
import { STORE_NAME } from '../../lib/site';
import { regions } from '../../data/regions';

interface Props {
  regionName: string;
  displayName: string;
  niche?: 'car' | 'truck';
  path: string;
}

const { regionName, displayName, path } = Astro.props;

// Filter out city-level links and unused regions mentioned by user
// "北海道" "横浜市""名古屋市" "福岡市""広島県""京都市""岡山県" are to be excluded or standardized.
// We'll use the standardized regions list.
const regionalLinks = regions.map(r => ({
    href: r.id === 'osaka' ? '/' : `/regions/${r.id}`,
    label: r.name
})).filter(l => !["北海道", "横浜市", "名古屋市", "福岡市", "京都市", "広島県", "岡山県"].includes(l.label));
---

<section class="py-10 bg-white">
    <div class="container mx-auto px-8 text-center max-w-4xl">
        <h2 class="text-3xl font-bold text-primary mb-6">
            {displayName}の車内空間を、もっときれいに。
        </h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-6">
            私たちは、{displayName}のお客様が車内の不快な臭いを我慢することなく、<br />
            快適なドライブを楽しめるよう誠心誠意スピード対応をお約束します。<br />
            単なる車内清掃を超えた、プロの洗浄をご提供します。
        </p>

        <hr class="my-6 border-gray-200" />

        <h3 class="text-2xl font-bold text-gray-800 mb-6">
            私たちの約束：「二度と臭わない空間へ」
        </h3>
        
        <div class="bg-blue-50 p-6 md:p-8 rounded-2xl text-left mb-10 border border-blue-100">
            <p class="text-gray-700 leading-relaxed mobile-text">
                車内のトラブルは、目に見える汚れだけでなく「目に見えない菌や臭いの原因」が問題です。<br />
                私たちは{displayName}の地で、年間多くの施工実績を積み重ねてきました。<br />
                「他店で断られた」「自分でやってみたけどダメだった」という方こそ、ぜひ一度ご相談ください。<br />
                最新の100℃スチーム洗浄技術で、あなたの愛車を新車のような清潔な空間へ蘇らせます。
            </p>
        </div>

        <div class="space-y-4">
            <p class="text-sm font-bold text-gray-500 uppercase tracking-widest">対応エリア一覧</p>
            <div class="flex flex-wrap justify-center gap-3">
                {regionalLinks.map((link) => (
                    <a 
                        href={link.href}
                        class="text-primary hover:text-white hover:bg-primary bg-white px-3 py-1.5 rounded shadow-sm border border-gray-200 transition-colors"
                    >
                        {link.label}
                    </a>
                ))}
            </div>
        </div>
    </div>
</section>

{/* Copyright */}
<footer class="bg-gray-900 text-white py-6 text-center text-sm">
    <p>&copy; {new Date().getFullYear()} {STORE_NAME} All Rights Reserved.</p>
</footer>
