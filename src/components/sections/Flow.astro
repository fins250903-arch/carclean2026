---
interface Props {
  niche?: 'car' | 'truck';
}

const { niche = 'car' } = Astro.props;
const isTruck = niche === 'truck';

const steps = [
    {
        title: "お問い合わせ",
        desc: "お電話またはLINE・インスタDMにてお問い合わせください。状況をお伺いし、概算のお見積もりを提示します。",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone-call"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/><path d="m18.5 1.5 3 3L16 10"/></svg>'
    },
    {
        title: "現場へ急行・状態確認",
        desc: "ご指定の場所へ伺い、実際の汚れや臭いの原因をプロの目で診断。最終的な費用を説明し、納得いただいてから作業開始します。",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>'
    },
    {
        title: "洗浄・消臭施工",
        desc: isTruck ? "100℃の高温スチームでキャビン内を丸洗い。シート、ベッド、フロアマットまで徹底的に除菌・消臭します。" : "100℃の高温スチームと業務用リンサーを用い、シートやフロアの汚れを根こそぎ吸引・洗浄します。",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>'
    },
    {
        title: "抗菌コート・お引き渡し",
        desc: "仕上げに抗菌・防カビコートを施し、お客様に確認いただいて完了です。施工後すぐに使用可能です。",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-circle"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
    }
];
---

<section class="py-10 bg-white" id="flow">
    <div class="container mx-auto px-8">
        <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">
            サービスの流れ
        </h2>

        <div class="max-w-5xl mx-auto relative">
            <div class="hidden md:block absolute top-1/2 left-0 right-0 h-1 bg-primary/20 -translate-y-1/2 z-0"></div>
            
            <div class="grid md:grid-cols-4 gap-8">
                {steps.map((step, index) => (
                    <div class="relative z-10 flex flex-col items-center">
                        <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mb-6 shadow-lg border-4 border-white">
                            <Fragment set:html={step.icon} />
                        </div>
                        <div class="bg-gray-50 rounded-xl p-6 text-center border border-gray-100 flex-1">
                            <div class="text-xs font-bold text-primary mb-2">STEP {index + 1}</div>
                            <h3 class="text-lg font-bold text-gray-800 mb-3">{step.title}</h3>
                            <p class="text-sm text-gray-600 leading-relaxed text-left">
                                {step.desc}
                            </p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
